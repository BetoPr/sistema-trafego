# env files (can opt-in for committing if needed)
.env*
!.env.example

# scripts locais com credenciais (ex: fix-env.ps1) — NUNCA commitar
*.ps1
*.sh
.fix-env*

# brainstorm visual companion (mockups descartáveis)
.superpowers/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

