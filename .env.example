# =========================================================
# Supabase (preencher após criar projeto em supabase.com)
# Use o NOVO modelo (sb_publishable_* / sb_secret_*). As variáveis
# legacy NEXT_PUBLIC_SUPABASE_ANON_KEY/SUPABASE_SERVICE_ROLE_KEY ainda
# são aceitas via fallback durante transição mas devem ser removidas.
# =========================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# =========================================================
# App
# =========================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =========================================================
# Criptografia tokens OAuth (AES-256-GCM, app-level)
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 64 chars hex (= 32 bytes)
# =========================================================
ENCRYPTION_KEY=

# =========================================================
# OAuth state CSRF (HMAC-SHA256)
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =========================================================
OAUTH_STATE_SECRET=

# =========================================================
# Meta Ads (preencher após criar app em developers.facebook.com)
# =========================================================
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/oauth/meta/callback
META_API_VERSION=v21.0

# =========================================================
# IA Provider — escolher: ollama | groq | claude
# =========================================================
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
GROQ_API_KEY=
ANTHROPIC_API_KEY=
